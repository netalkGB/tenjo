{
  "name": "tenjo-server",
  "version": "0.0.2",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec \"node scripts/dev.js\" --ext ts --ignore dist/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "clean": "node scripts/clean.js",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "migrate": "node dist/db/runMigration.js"
  },
  "dependencies": {
    "@phc/format": "^1.0.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.2.2",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "http-status-codes": "^2.3.0",
    "pg": "^8.16.3",
    "source-map-support": "^0.5.21",
    "tenjo-chat-engine": "*",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/jpeg-js": "^0.3.0",
    "@types/node": "^25.4.0",
    "@types/pg": "^8.15.5",
    "@types/source-map-support": "^0.5.10",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "cross-spawn": "^7.0.6",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.0"
